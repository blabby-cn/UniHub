<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 主内容区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/primary"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu"
                android:tint="@color/on_primary"
                android:contentDescription="@string/menu" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnUndo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_undo"
                android:tint="@color/on_primary"
                android:layout_marginHorizontal="12dp"
                android:contentDescription="@string/undo" />

            <ImageView
                android:id="@+id/btnRedo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_redo"
                android:tint="@color/on_primary"
                android:layout_marginHorizontal="12dp"
                android:contentDescription="@string/redo" />

            <ImageView
                android:id="@+id/btnSave"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_save"
                android:tint="@color/on_primary"
                android:layout_marginHorizontal="12dp"
                android:contentDescription="@string/save_description" />

            <ImageView
                android:id="@+id/btnEditTools"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/on_primary"
                android:layout_marginHorizontal="12dp"
                android:contentDescription="@string/tools_description" />

            <ImageView
                android:id="@+id/btnOverflow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more"
                android:tint="@color/on_primary"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/more" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/surface">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/untitled"
                android:textColor="@color/on_surface"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UTF-8"
                android:textColor="@color/outline"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 使用 FrameLayout 实现行号与编辑器同步滚动 -->
        <FrameLayout
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical|horizontal"
                android:overScrollMode="always">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvLineNumbers"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:textColor="@color/outline"
                        android:textSize="18sp"
                        android:gravity="end"
                        android:padding="8dp"
                        android:typeface="monospace"
                        android:minHeight="48dp" />

                    <EditText
                        android:id="@+id/etEditor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:padding="8dp"
                        android:typeface="monospace"
                        android:scrollHorizontally="true"
                        android:overScrollMode="always"
                        android:cursorVisible="true"
                        android:importantForAutofill="no" />

                </LinearLayout>

            </HorizontalScrollView>

        </FrameLayout>

        <!-- 底部符号栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/primary_container"
            android:padding="12dp"
            android:gravity="center"
            android:id="@+id/bottomBar">

            <TextView
                android:id="@+id/btnSymbolRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolSlash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolStar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolEqual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="="
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolLt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

            <TextView
                android:id="@+id/btnSymbolGt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/on_primary"
                android:textSize="18sp"
                android:layout_marginHorizontal="16dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 全屏预览视图（初始隐藏） -->
    <LinearLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/primary"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnPreviewBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/on_primary"
                android:contentDescription="@string/back_description" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/preview"
                android:textColor="@color/on_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp" />

        </LinearLayout>

        <WebView
            android:id="@+id/webPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

    <!-- 侧边栏菜单 -->
    <LinearLayout
        android:id="@+id/sideMenu"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/primary"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/md_editor"
                android:textColor="@color/on_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnNewFile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/on_primary"
                android:layout_marginHorizontal="12dp"
                android:contentDescription="@string/new_file_hint" />

            <ImageView
                android:id="@+id/btnSideMenuMore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more"
                android:tint="@color/on_primary"
                android:contentDescription="@string/more" />

        </LinearLayout>

        <ListView
            android:id="@+id/lvFileHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/background"
            android:divider="@color/primary_container"
            android:dividerHeight="1dp"
            android:overScrollMode="always" />

        <Button
            android:id="@+id/btnMinimize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/minimize"
            android:background="@color/primary"
            android:textColor="@color/on_primary"
            android:layout_margin="16dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>