<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.Blabby.Co.UniHub">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@drawable/icon"
        android:label="Unihub"
        android:roundIcon="@drawable/icon"
        android:supportsRtl="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.UniHub">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".SettingsActivity" />
        <activity android:name=".DocumentActivity" />
        <activity android:name=".VideoSee"
            android:label="Unihub 视频查看器" />
        <activity android:name=".ZipLiulan"
            android:label="Unihub 压缩包浏览器" />
        <activity android:name=".WenbenBianjiqi"
            android:label="Unihub 文本编辑器" />
        <activity android:name=".GeshihuaBianji"
            android:label="Unihub Markdown编辑器" />
        <activity android:name=".DocsActivity" />
        <activity android:name=".DownloadActivity" />
        <activity android:name=".EditSettingsActivity" />

    </application>
</manifest>